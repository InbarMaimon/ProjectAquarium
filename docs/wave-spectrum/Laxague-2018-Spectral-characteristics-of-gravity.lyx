\begin_layout Plain Layout
Let 
\begin_inset Formula $N$
\end_inset

 be the number of pixels,
 
\begin_inset Formula $L$
\end_inset

 be physical the side length of the image,
 
\begin_inset Formula $ds$
\end_inset

 be the slope sensitivity,
 
\begin_inset Formula $f_{0}\equiv\frac{\Omega_{0}}{2\pi}$
\end_inset

 be the sampling rate and 
\begin_inset Formula $T$
\end_inset

 be the film duration.
 Let 
\begin_inset Formula $F\left(\omega,k_{x},k_{y}\right)$
\end_inset

 be the Fourier transform of the video.
 Then
\end_layout

\end_inset


\end_layout

\begin_layout Standard
Let 
\begin_inset Formula $s\left(k\right):=kA\left(k\right)$
\end_inset

 be the per 
\begin_inset Formula $k$
\end_inset

 slope.
 The data is discrete,
 with
\begin_inset Formula 
\begin{align*}
S\left(k_{x},k_{y},\omega\right) & =\frac{1}{Nk_{max}^{2}\Omega_{0}}\left(\left|F\left(k_{x},k_{y},\omega\right)\cdot\frac{dz_{x}}{dx}\right|^{2}+\left|F\left(k_{x},k_{y},\omega\right)\cdot\frac{dz_{y}}{dy}\right|^{2}\right),
\end{align*}

\end_inset

where 
\begin_inset Formula $k_{max}:=\frac{2\pi}{L}\sqrt{N}$
\end_inset

 is a shorthand notation and 
\begin_inset Formula $dz_{x}$
\end_inset

,
 
\begin_inset Formula $dz_{y}$
\end_inset

 are the 
\begin_inset Formula $3D$
\end_inset

 spatiotemporal arrays defined by 
\begin_inset Formula 
\begin{align*}
dz_{x}\left(t,x,y\right) & :=z\left(t,x,y\right)-z\left(t,x-1,y\right),\\
dz_{y}\left(t,x,y\right) & :=z\left(t,x,y\right)-z\left(t,x,y-1\right).
\end{align*}

\end_inset

Taking into notice that 
\begin_inset Formula $dx=dy=2\pi/k_{max}$
\end_inset

,
 and taking 
\begin_inset Formula $F\left(k_{x},k_{y},\omega\right)_{t,x,y}:=\frac{1}{\sqrt{N}}e^{-i\left(\omega t-k_{x}x-k_{y}y\right)}$
\end_inset

 to be unitary,
 we find that
\begin_inset Formula 
\begin{align*}
S\left(k_{x},k_{y},\omega\right) & =\frac{1}{\left(2\pi\right)^{2}\Omega_{0}}\left(\left|F\left(k_{x},k_{y},\omega\right)\cdot dz_{x}\right|^{2}+\left|F\left(k_{x},k_{y},\omega\right)\cdot dz_{y}\right|^{2}\right)
\end{align*}

\end_inset

has units of 
\begin_inset Formula $m^{2}s$
\end_inset

.
 One may define the total slope as 
\begin_inset Formula $s=\sqrt{s_{x}^{2}+s_{y}^{2}}$
\end_inset

,
 then the total slope variance,
 or 
\series bold
mean square slope
\series default
,
 over a dataset is
\family roman
\series medium
\shape up
\size normal
\emph off
\nospellcheck off
\bar no
\strikeout off
\xout off
\uuline off
\uwave off
\noun off
\color none
 
\family default
\series default

\nospellcheck default
\bar default
\strikeout default
\xout default
\uuline default
\uwave default
\noun default
\color inherit

\begin_inset Formula 
\begin{align*}
\left\langle s^{2}\right\rangle  & =\frac{\sum_{t,x,y}s\left(t,x,y\right)^{2}}{NTf_{0}}\\
 & =\frac{\sum_{\omega,k_{x},k_{y}}\left(\left|F\cdot s_{x}\right|^{2}+\left|F\cdot s_{y}\right|^{2}\right)}{NTf_{0}}\\
 & =\frac{1}{NTf_{0}}\cdot Nk_{max}^{2}\Omega_{0}\sum_{\omega,k_{x},k_{y}}S\\
 & =k_{max}^{2}\sum_{k_{x},k_{y}}\left(k_{x}^{2}+k_{y}^{2}\right)^{-1}\mathcal{B}\left(k_{x},k_{y}\right)\\
 & \approx k_{max}^{2}\sum_{k,\phi}\left(k_{x}^{2}+k_{y}^{2}\right)^{-1/2}\mathcal{B}\left(k,\phi\right)\\
 & =N\frac{k_{max}}{\sqrt{N}}\sum_{k}k^{-1}B\left(k\right),
\end{align*}

\end_inset

where I defined the discrete versions of 
\begin_inset Formula $\mathcal{B}$
\end_inset

,
 
\begin_inset Formula $B$
\end_inset

 by
\begin_inset Formula 
\begin{align*}
\mathcal{B}\left(k_{x},k_{y}\right) & =\frac{2\pi}{T}k^{2}\sum_{\omega}S,\\
B\left(k\right) & =\frac{2\pi}{L}\sum_{\phi}\mathcal{B}\left(k,\phi\right)=\frac{k_{max}}{\sqrt{N}}\sum_{\phi}\mathcal{B}\left(k,\phi\right).
\end{align*}

\end_inset


\end_layout


\begin_layout Plain Layout
A general sea patch has an average slope,
 so we may have an RMS plane 
\begin_inset Formula 
\begin{align*}
p\left(t,x,y\right) & =A\left(t\right)x+B\left(t\right)y+C\left(t\right)\\
\implies p\left(\omega,k_{x},k_{y}\right) & =-\frac{i}{L}A\left(\omega\right)\frac{\left(Lk_{x}\cos\left(k_{x}L/2\right)-2\sin\left(k_{x}L/2\right)\right)}{k_{x}^{2}}\delta_{k_{y},0}\\
 & -\frac{i}{L}B\left(\omega\right)\frac{\left(Lk_{y}\cos\left(k_{y}L/2\right)-2\sin\left(k_{y}L/2\right)\right)}{k_{y}^{2}}\delta_{k_{x},0}\\
 & +C\left(\omega\right)\delta_{k_{x},0}\delta_{k_{y},0}
\end{align*}

\end_inset

We are interested only in finite 
\begin_inset Formula $k$
\end_inset

s,
 so we can also ignore anything 
\begin_inset Formula $C\left(\omega\right)$
\end_inset

-related.
 Then
\begin_inset Formula 
\begin{align*}
p\left(\omega,k_{x},k_{y}\right) & =-\frac{i}{L}A\left(\omega\right)\frac{\left(Lk_{x}\cos\left(k_{x}L/2\right)-2\sin\left(k_{x}L/2\right)\right)}{k_{x}^{2}}\delta_{k_{y},0}\\
 & -\frac{i}{L}B\left(\omega\right)\frac{\left(Lk_{y}\cos\left(k_{y}L/2\right)-2\sin\left(k_{y}L/2\right)\right)}{k_{y}^{2}}\delta_{k_{x},0}
\end{align*}

\end_inset

and
\begin_inset Formula 
\begin{align*}
\left|p\left(\omega,k_{x},k_{y}\right)\right|^{2} & =\frac{1}{L^{2}}A\left(\omega\right)^{2}\frac{\left(Lk_{x}\cos\left(k_{x}L/2\right)-2\sin\left(k_{x}L/2\right)\right)^{2}}{k_{x}^{4}}\delta_{k_{y},0}\\
 & +\frac{1}{L^{2}}B\left(\omega\right)^{2}\frac{\left(Lk_{y}\cos\left(k_{y}L/2\right)-2\sin\left(k_{y}L/2\right)\right)^{2}}{k_{y}^{4}}\delta_{k_{x},0}\\
 & +2\frac{1}{L^{2}}A\left(\omega\right)B\left(\omega\right)\cancel{\frac{Lk_{y}-\frac{1}{2}Lk_{y}\left(Lk_{y}/2\right)^{2}-2k_{y}L/2+\frac{1}{3}\left(k_{y}L/2\right)^{3}+O\left(k_{y}^{5}\right)}{k_{y}^{2}}}\cdot\cancel{O\left(k_{x}^{3}\right)}\delta_{k_{x},0}\delta_{k_{y},0}\\
 & =\frac{1}{L^{2}}A\left(\omega\right)^{2}\frac{\left(Lk_{x}\cos\left(k_{x}L/2\right)-2\sin\left(k_{x}L/2\right)\right)^{2}}{k_{x}^{4}}\delta_{k_{y},0}\\
 & +\frac{1}{L^{2}}B\left(\omega\right)^{2}\frac{\left(Lk_{y}\cos\left(k_{y}L/2\right)-2\sin\left(k_{y}L/2\right)\right)^{2}}{k_{y}^{4}}\delta_{k_{x},0}
\end{align*}

\end_inset

which in the limits of small/large 
\begin_inset Formula $kL$
\end_inset

 takes the form 
\begin_inset Formula 
\begin{align*}
p\left(\omega,k_{x},k_{y}\right) & =\begin{cases}
\frac{i}{12}L^{2}\left(A\left(\omega\right)k_{x}\delta_{k_{y},0}+B\left(\omega\right)k_{y}\delta_{k_{x},0}\right) & kL\rightarrow0\\
-iA\left(\omega\right)\frac{\cos\left(k_{x}L/2\right)}{k_{x}}\delta_{k_{y},0}-iB\left(\omega\right)\frac{\cos\left(k_{y}L/2\right)}{k_{y}}\delta_{k_{x},0} & kL\gg1
\end{cases},\\
\left|p\left(\omega,k_{x},k_{y}\right)\right|^{2} & =\begin{cases}
\frac{1}{144}L^{4}\left(\left|A\left(\omega\right)\right|^{2}k_{x}^{2}\delta_{k_{y},0}+\left|B\left(\omega\right)\right|^{2}k_{y}^{2}\delta_{k_{x},0}\right) & kL\rightarrow0\\
\left|A\left(\omega\right)\right|^{2}\frac{\cos^{2}\left(k_{x}L/2\right)}{k_{x}^{2}}\delta_{k_{y},0}+\left|B\left(\omega\right)\right|^{2}\frac{\cos^{2}\left(k_{y}L/2\right)}{k_{y}^{2}}\delta_{k_{x},0} & kL\gg1
\end{cases}.
\end{align*}

\end_inset

So if 
\begin_inset Formula $\zeta$
\end_inset

 is the elevation,
 let us define 
\begin_inset Formula $e:=\zeta-p$
\end_inset

 and then over a finite square of size 
\begin_inset Formula $L^{2}$
\end_inset

 and duration 
\begin_inset Formula $T$
\end_inset

,
 we find
\end_layout

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
C\left(t,r\right) & :=\int\int dxdye\left(t,x+r_{x},y+r_{y}\right)e\left(t,x,t\right)\\
\implies C\left(t,r\right) & =\int_{0}^{\infty}\frac{d\omega}{2\pi}\mathcal{F}^{-1}\left(\left|\mathcal{F}\left(e\right)\right|^{2}\right)\left(t,r\right)\\
 & =\int_{0}^{\infty}\frac{d\omega}{2\pi}\mathcal{F}^{-1}\left(\left|\mathcal{F}\left(\zeta\right)\right|^{2}+2\Re\left(\mathcal{F}\left(\zeta\right)\mathcal{F}\left(p\right)^{*}\right)+\left|\mathcal{F}\left(p\right)\right|^{2}\right)\left(t,r\right)\\
 & =\int\int\frac{d^{2}k}{\left(2\pi\right)^{2}}e^{i\left(r_{x}k_{x}+r_{y}k_{y}-\omega t\right)}k^{-2}S\left(k_{x},k_{y}\right)\\
 & +2\int_{0}^{\infty}\frac{d\omega}{2\pi}\mathcal{F}^{-1}\Re\left(\mathcal{F}\left(\zeta\right)\mathcal{F}\left(p\right)^{*}\right)\\
 & +\int_{0}^{\infty}\frac{d\omega}{2\pi}\mathcal{F}^{-1}\left|\mathcal{F}\left(p\right)\right|^{2}\\
 & =\int\int\frac{kdkd\phi}{\left(2\pi\right)^{2}}e^{i\left(r_{x}k\cos\phi+r_{y}k\sin\phi-\omega t\right)}k^{-2}S\left(\omega,k,\phi\right)\\
\implies C\left(r\right) & :=\int_{0}^{\infty}\frac{d\omega}{2\pi}C\left(\omega,r\right)\\
 & =\frac{1}{\left(2\pi\right)^{2}}\int\frac{dk}{k}\int d\phi e^{i\left(r_{x}k\cos\phi+r_{y}k\sin\phi\right)}S\left(k,\phi\right).
\end{align*}

\end_inset

In the paper,
 the 
\begin_inset Formula $S\left(k,\phi\right)$
\end_inset

 they measured is anisotropic (fig.
 3).
 We calculate the isotropic approximation:
\begin_inset Formula 
\begin{align*}
C\left(r\right) & \approx\frac{1}{\left(2\pi\right)^{2}}\int\frac{dk}{k}\int d\phi e^{ik\left(r\cos\phi+r_{y}\sin\phi\right)}\int\frac{d\phi'}{2\pi}S\left(k,\phi'\right)\\
 & =\frac{1}{\left(2\pi\right)^{2}}\int\frac{dk}{k}J_{0}\left(kr\right)S\left(k\right).
\end{align*}

\end_inset

The discrete counterpart is then
\begin_inset Formula 
\begin{align*}
\frac{C\left(r\right)}{C\left(0\right)} & =\frac{\sum_{k}k^{-1}J_{0}\left(kr\right)S\left(k\right)}{\sum_{k}k^{-1}S\left(k\right)}\\
 & =\frac{\sum_{k}k^{-3}J_{0}\left(kr\right)B\left(k\right)}{\sum_{k}k^{-3}B\left(k\right)}
\end{align*}

\end_inset


\end_layout

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
C\left(t,r\right) & :=\int\int dxdys\left(t,x+r_{x},y+r_{y}\right)s\left(t,x,t\right)\\
\implies C\left(t,r\right) & =\int_{0}^{\infty}\frac{d\omega}{2\pi}\mathcal{F}^{-1}\left(\left|\mathcal{F}\left(s\right)\right|^{2}\right)\left(t,r\right)\\
 & =\int_{0}^{\infty}\frac{d\omega}{2\pi}\int\int\frac{d^{2}k}{\left(2\pi\right)^{2}}e^{i\left(r_{x}k_{x}+r_{y}k_{y}-\omega t\right)}S\left(\omega,k_{x},k_{y}\right)\\
 & =\int_{0}^{\infty}\frac{d\omega}{2\pi}\int\int\frac{kdkd\phi}{\left(2\pi\right)^{2}}e^{i\left(r_{x}k\cos\phi+r_{y}k\sin\phi-\omega t\right)}S\left(\omega,k,\phi\right)\\
\implies C\left(r\right) & :=\int_{0}^{\infty}\frac{d\omega}{2\pi}C\left(\omega,r\right)\\
 & =\int\frac{kdk}{\left(2\pi\right)^{2}}\int d\phi e^{i\left(r_{x}k\cos\phi+r_{y}k\sin\phi\right)}S\left(k,\phi\right).
\end{align*}

\end_inset

In the paper,
 the 
\begin_inset Formula $S\left(k,\phi\right)$
\end_inset

 they measured is anisotropic (fig.
 3).
 We calculate the isotropic approximation:
\begin_inset Formula 
\begin{align*}
C\left(r\right) & \approx\int\frac{kdk}{\left(2\pi\right)^{2}}\int d\phi e^{ik\left(r\cos\phi+r_{y}\sin\phi\right)}\int\frac{d\phi'}{2\pi}S\left(k,\phi'\right)\\
 & =\frac{1}{2\pi}\int\frac{kdk}{2\pi}J_{0}\left(kr\right)S\left(k\right),
\end{align*}

\end_inset

where we approximated
\begin_inset Formula 
\begin{align*}
S\left(k\right) & :=\int d\phi'S\left(k,\phi'\right).
\end{align*}

\end_inset

Then
\begin_inset Formula 
\begin{align*}
\sigma^{2}\equiv\frac{C\left(0\right)}{L^{2}} & \approx\frac{1}{L^{2}}\frac{1}{2\pi}\int\frac{kdk}{2\pi}S\left(k\right)\\
 & =\frac{1}{\left(2\pi L\right)^{2}}\int dkk^{-1}B\left(k\right).
\end{align*}

\end_inset

The discrete counterpart is then
\begin_inset Formula 
\begin{align*}
\frac{C\left(r\right)}{C\left(0\right)} & =\frac{\sum_{k}kJ_{0}\left(kr\right)S\left(k\right)}{\sum_{k}kS\left(k\right)}\\
 & =\frac{\sum_{k}k^{-1}J_{0}\left(kr\right)B\left(k\right)}{\sum_{k}k^{-1}B\left(k\right)}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
This estimation turns out as 
\begin_inset Formula $2-7cm$
\end_inset

 in length.
 The correlation length for heights will be longer,
 so we can safely set,
 say,
 
\begin_inset Formula $1cm$
\end_inset

 as a hard lower bar for the physical resolution.
\end_layout

\begin_layout Subsubsection
\start_of_appendix
Convolution theorem
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\mathcal{F}\left(f*g\right)\left(k\right) & =\int\int f\left(x\right)g\left(x'-x\right)e^{ikx'}dxdx'\\
 & =\frac{1}{\left(2\pi\right)^{^{2}}}\int\int\int dk'f\left(k'\right)e^{-ik'x}\int dk''g\left(k''\right)e^{-ik''\left(x'-x\right)}e^{ikx'}dxdx'\\
 & =\frac{1}{\left(2\pi\right)^{^{2}}}\int dk'f\left(k'\right)\int dk''g\left(k''\right)\int e^{-ik'x}e^{ik''x}dx\int e^{-ik''x'}e^{ikx'}dx'\\
 & =\frac{1}{\left(2\pi\right)^{^{2}}}\int dk'f\left(k'\right)\int dk''g\left(k''\right)2\pi\delta\left(k'-k''\right)2\pi\delta\left(k-k''\right)\\
 & =f\left(k\right)g\left(k\right)\\
\implies\mathcal{F}^{-1}\left(\left|f\left(k\right)\right|^{2}\right) & =f\left(x\right)*f\left(-x\right)\\
 & =\int dxf\left(x\right)f\left(x-x'\right)dx,\\
\int f\left(x\right)g\left(x\right)e^{ikx}dx & =\frac{1}{\left(2\pi\right)^{^{2}}}\int\int\int dk'f\left(k'\right)e^{-ik'x}\int dk''g\left(k''\right)e^{-ik''x}e^{ikx}dx\\
 & =\frac{1}{2\pi}\int dk'f\left(k'\right)g\left(k-k'\right)\\
\implies\int f\left(x\right)^{2}dx & =\frac{1}{2\pi}\int dk'f\left(k'\right)f\left(-k'\right)\\
 & =\frac{1}{2\pi}\int dk'\left|f\left(k'\right)\right|^{2},\\
\sum_{x}f\left(x\right)g\left(x\right)e^{ikx} & =\frac{1}{N}\sum_{x}\sum_{k'}f\left(k'\right)e^{-ik'x}\sum_{k''}g\left(k''\right)e^{-ik''x}e^{ikx}\\
 & =\sum_{k'}f\left(k'\right)\sum_{k''}g\left(k''\right)\delta_{k'',k-k'}\\
 & =\sum_{k'}f\left(k'\right)g\left(k-k'\right)\\
\implies\sum_{x}f\left(x\right)^{2} & =\sum_{k'}\left|f\left(k'\right)\right|^{2}
\end{align*}

\end_inset

Also if 
\begin_inset Formula $g\left(x\right):=f\left(-x\right)$
\end_inset

 then 
\begin_inset Formula $\mathcal{F}\left(f*g\right)\left(k\right)=\left|f\left(k\right)\right|^{2}$
\end_inset

 is the power spectrum.
\end_layout


\begin_layout Section
Nonlinear Theory
\end_layout

\begin_layout Subsection
Resonance condition for harmonic generationc
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\omega^{2} & =g\left|k\right|+\frac{\tau}{\rho}\left|k\right|^{3},\\
\omega_{n} & =n\omega_{1},\\
k_{n} & =sk_{1}\\
\implies gs\left|k_{1}\right|+\frac{\tau}{\rho}s^{3}\left|k_{1}\right|^{3} & =n^{2}\left(g\left|k_{1}\right|+\frac{\tau}{\rho}\left|k_{1}\right|^{3}\right)\\
\implies0 & =\left(n^{2}-s\right)g+\left(n^{2}-s^{3}\right)\frac{\tau}{\rho}\left|k_{1}\right|^{2}\\
\implies\left|k_{1}\right| & =\left(-\frac{\left(n^{2}-s\right)\rho g}{\left(n^{2}-s^{3}\right)\tau}\right)^{1/2}\\
\implies\omega_{1} & =\sqrt{g\left(-\frac{\left(n^{2}-s\right)\rho g}{\left(n^{2}-s^{3}\right)\tau}\right)^{1/2}+\frac{\tau}{\rho}\left(-\frac{\left(n^{2}-s\right)\rho g}{\left(n^{2}-s^{3}\right)\tau}\right)^{3/2}.}
\end{align*}

\end_inset

Plug in 
\begin_inset Formula $n=s=2,3,4$
\end_inset

 and find that for clean water at the earth's surface,
 at room temperature,
 where 
\begin_inset Formula $g\approx10\frac{m}{s^{2}}$
\end_inset

,
 
\begin_inset Formula $\rho\approx10^{3}\frac{kg}{m^{3}}$
\end_inset

,
 
\begin_inset Formula $\tau\approx0.072\frac{kg}{s^{2}}$
\end_inset

,
 we have
\begin_inset Formula 
\[
\begin{cases}
\frac{\left|k_{1}\right|}{2\pi}=\left(\frac{\rho g}{2\tau}\right)^{1/2}\approx0.04mm^{-1} & n=2\\
\frac{\omega_{1}}{2\pi}=\left(\frac{9\rho g^{3}}{8\tau}\right)^{1/4}\approx600Hz\\
\left|k_{1}\right|=\left(\frac{\rho g}{3\tau}\right)^{1/2} & n=3\\
\omega_{1}=\left(\frac{16\rho g^{3}}{27\tau}\right)^{1/4}\\
\left|k_{1}\right|=\left(\frac{\rho g}{4\tau}\right)^{1/2} & n=4\\
\omega_{1}=\left(\frac{25\rho g}{64\tau}\right)^{1/4}
\end{cases}
\]

\end_inset



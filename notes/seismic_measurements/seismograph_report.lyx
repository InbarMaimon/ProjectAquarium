reference "fig:15/2 dist. work hours"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

.
\end_layout

\begin_layout Subsection
Shed-lab variations
\end_layout

\begin_layout Standard
Fig.
 
\begin_inset CommandInset ref
